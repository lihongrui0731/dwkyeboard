dictbuilder.o: share/dictbuilder.cpp include/dictbuilder.h \
		include/utf16char.h \
		include/dictdef.h \
		include/dictlist.h \
		include/searchutility.h \
		include/spellingtrie.h \
		include/spellingtable.h \
		include/splparser.h \
		include/dicttrie.h \
		include/atomdictbase.h \
		include/mystdlib.h \
		include/ngram.h \
		include/utf16reader.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o dictbuilder.o share/dictbuilder.cpp

