	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o abstractinputpanel.o src/abstractinputpanel.cpp

appinputpanel.o: src/appinputpanel.cpp include/appinputpanel.h \
		include/abstractinputpanel.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o appinputpanel.o src/appinputpanel.cpp

