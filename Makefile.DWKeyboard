DWKeyboard.pro:
content/styles/default/default_style.qrc:
qml.qrc:
qmake: FORCE
	@$(QMAKE) -o Makefile.DWKeyboard DWKeyboard.pro

qmake_all: FORCE


all: Makefile.DWKeyboard \
		/lib/libdwkeyboard.prl /lib/libdwkeyboard.a

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents content/styles/default/default_style.qrc qml.qrc $(DISTDIR)/
	$(COPY_FILE) --parents /usr/lib/x86_64-linux-gnu/qt5/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents include/qmlinputcontroller.h include/dwkeyboard_global.h include/KeyboardGlobal.h include/abstractinputmethod.h include/abstractinputpanel.h include/appinputpanel.h include/defaultinputmethod.h include/desktopinputpanel2.h include/inputcontext.h include/inputengine.h include/inputmethod.h include/inputview.h include/pinyindecoderservice.h include/pinyininputmethod.h include/plaininputmethod.h include/platforminputcontext.h include/plugin.h include/selectionlistmodel.h include/settings.h include/shifthandler.h include/trace.h include/virtualkeyboarddebug.h $(DISTDIR)/
	$(COPY_FILE) --parents KeyboardGlobal.cpp src/qmlinputcontroller.cpp src/abstractinputmethod.cpp src/abstractinputpanel.cpp src/appinputpanel.cpp src/defaultinputmethod.cpp src/desktopinputpanel2.cpp src/inputcontext.cpp src/inputengine.cpp src/inputmethod.cpp src/inputview.cpp src/pinyindecoderservice.cpp src/pinyininputmethod.cpp src/plaininputmethod.cpp src/platforminputcontext.cpp src/plugin.cpp src/selectionlistmodel.cpp src/settings.cpp src/shifthandler.cpp src/trace.cpp $(DISTDIR)/


clean: compiler_clean
	-$(DEL_FILE) $(OBJECTS)
	-$(DEL_FILE) *~ core *.core


distclean: clean
	-$(DEL_FILE) /lib/$(TARGET)
	-$(DEL_FILE) .qmake.stash /lib/libdwkeyboard.prl
	-$(DEL_FILE) Makefile.DWKeyboard


####### Sub-libraries

mocclean: compiler_moc_header_clean compiler_moc_objc_header_clean compiler_moc_source_clean

mocables: compiler_moc_header_make_all compiler_moc_objc_header_make_all compiler_moc_source_make_all

check: first

benchmark: first

compiler_rcc_make_all: qrc_default_style.cpp qrc_qml.cpp
compiler_rcc_clean:
	-$(DEL_FILE) qrc_default_style.cpp qrc_qml.cpp
qrc_default_style.cpp: content/styles/default/default_style.qrc \
		/usr/lib/qt5/bin/rcc \
		content/styles/default/images/globe-868482.svg \
		content/styles/default/images/shift-80c342.svg \
		content/styles/default/images/shift-c5d6b6.svg \
		content/styles/default/images/handwriting-868482.svg \
		content/styles/default/images/textmode-868482.svg \
		content/styles/default/images/selectionhandle-bottom.svg \
		content/styles/default/images/BtnBg.png \
		content/styles/default/images/shift-868482.svg \
		content/styles/default/images/search-868482.svg \
		content/styles/default/images/hidekeyboard-868482.svg \
		content/styles/default/images/backspace-868482.svg \
		content/styles/default/images/check-868482.svg \
		content/styles/default/images/enter-868482.svg \
		content/styles/default/images/keyboardBg.png
	/usr/lib/qt5/bin/rcc -name default_style content/styles/default/default_style.qrc -o qrc_default_style.cpp

qrc_qml.cpp: qml.qrc \
		/usr/lib/qt5/bin/rcc \
		DWKeyboardPanel.qml
	/usr/lib/qt5/bin/rcc -name qml qml.qrc -o qrc_qml.cpp

compiler_moc_predefs_make_all: moc_predefs.h
compiler_moc_predefs_clean:
	-$(DEL_FILE) moc_predefs.h
moc_predefs.h: /usr/lib/x86_64-linux-gnu/qt5/mkspecs/features/data/dummy.cpp
	g++ -pipe -O2 -fPIC -std=gnu++1y -Wall -Wextra -dM -E -o moc_predefs.h /usr/lib/x86_64-linux-gnu/qt5/mkspecs/features/data/dummy.cpp

compiler_moc_header_make_all: moc_qmlinputcontroller.cpp moc_abstractinputmethod.cpp moc_abstractinputpanel.cpp moc_appinputpanel.cpp moc_defaultinputmethod.cpp moc_desktopinputpanel2.cpp moc_inputcontext.cpp moc_inputengine.cpp moc_inputmethod.cpp moc_inputview.cpp moc_pinyindecoderservice.cpp moc_pinyininputmethod.cpp moc_plaininputmethod.cpp moc_platforminputcontext.cpp moc_selectionlistmodel.cpp moc_settings.cpp moc_shifthandler.cpp moc_trace.cpp
compiler_moc_header_clean:
	-$(DEL_FILE) moc_qmlinputcontroller.cpp moc_abstractinputmethod.cpp moc_abstractinputpanel.cpp moc_appinputpanel.cpp moc_defaultinputmethod.cpp moc_desktopinputpanel2.cpp moc_inputcontext.cpp moc_inputengine.cpp moc_inputmethod.cpp moc_inputview.cpp moc_pinyindecoderservice.cpp moc_pinyininputmethod.cpp moc_plaininputmethod.cpp moc_platforminputcontext.cpp moc_selectionlistmodel.cpp moc_settings.cpp moc_shifthandler.cpp moc_trace.cpp
