KeyboardGlobal.o: KeyboardGlobal.cpp include/KeyboardGlobal.h \
		include/plugin.h \
		include/dwkeyboard_global.h \
		include/platforminputcontext.h \
		include/inputcontext.h \
		include/plaininputmethod.h \
		include/abstractinputmethod.h \
		include/inputengine.h \
		include/selectionlistmodel.h \
		include/pinyininputmethod.h \
		include/shifthandler.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o KeyboardGlobal.o KeyboardGlobal.cpp

qmlinputcontroller.o: src/qmlinputcontroller.cpp include/qmlinputcontroller.h \
		include/inputengine.h \
		include/dwkeyboard_global.h \
		include/KeyboardGlobal.h \
		include/plugin.h \
		include/platforminputcontext.h \
		include/inputcontext.h \
		include/plaininputmethod.h \
		include/abstractinputmethod.h \
		include/selectionlistmodel.h \
		include/pinyininputmethod.h \
		include/shifthandler.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o qmlinputcontroller.o src/qmlinputcontroller.cpp

